# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# This fork runs entirely on local models — no cloud APIs needed.
# Copy this file to .env and adjust values for your setup.
# Supports multiple LLM providers: Ollama (default), OpenRouter, OpenAI, NVIDIA NIM
# =============================================================

# ===== LLM Provider Selection =====
# Options: ollama (default), openrouter, openai, nvidia, custom
# If not specified, auto-detected from LLM_BASE_URL
LLM_PROVIDER=ollama

# ===== LLM Configuration (OpenAI-compatible format) =====
# For Ollama (local):
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
# Lighter model for development (less VRAM):
# LLM_MODEL_NAME=qwen2.5:14b

# For OpenRouter (cloud - uncomment to use):
# LLM_API_KEY=sk-or-v1-your-openrouter-api-key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=meta-llama/llama-3-70b-instruct
# Or try other models: google/gemma-2-27b-it, mistralai/mistral-large, etc.

# For NVIDIA NIM (cloud - uncomment to use):
# LLM_API_KEY=nvapi-your-nvidia-api-key
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Available models with optimized presets:
#   - mistralai/mistral-small-4-119b-2603 (reasoning_effort: high)
#   - nvidia/nemotron-3-super-120b-a12b (reasoning + thinking support)
#   - qwen/qwen3.5-122b-a10b (thinking support)
#   - minimaxai/minimax-m2.5
#   - qwen/qwen3.5-397b-a17b (thinking support)
#   - z-ai/glm5 (thinking support)
#   - stepfun-ai/step-3.5-flash
#   - moonshotai/kimi-k2.5 (thinking support)
#   - z-ai/glm4.7 (thinking support)
# Example:
# LLM_MODEL_NAME=mistralai/mistral-small-4-119b-2603

# ===== Ollama-specific Configuration =====
# Context window size for Ollama (prevents prompt truncation)
OLLAMA_NUM_CTX=8192

# ===== OpenRouter-specific Configuration =====
# Optional: Site URL and name for OpenRouter ranking
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=MiroFish-Offline
# Reasoning effort for models that support it (low, medium, high)
OPENROUTER_REASONING_EFFORT=medium

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration =====
# Uses Ollama's embedding endpoint (can be different from LLM provider)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# For Docker: EMBEDDING_BASE_URL=http://ollama:11434

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to same local Ollama server (or your chosen provider)
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Docker-mode overrides =====
# Uncomment these when running ALL services inside Docker
# (backend container talks to neo4j/ollama containers by service name)
# LLM_BASE_URL=http://ollama:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=http://ollama:11434/v1
